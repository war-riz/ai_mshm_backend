# ─────────────────────────────────────────────────────────────────────────────
#  AI-MSHM  –  Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-very-long-secret-key-here-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── postgresql ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:27017
# For Atlas: postgresql+srv://<user>:<pass>@cluster.postgres.net

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Mailgun example – swap for any provider) ────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=
DEFAULT_FROM_EMAIL=AI-MSHM <noreply@ai-mshm.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Sentry (production only) ──────────────────────────────────────────────────
SENTRY_DSN=
