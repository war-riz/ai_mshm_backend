# ─────────────────────────────────────────────────────────────────────────────
#  AI-MSHM  –  Environment Variables (Development)
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Use Supabase / Railway / Neon / local Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Example (Supabase):
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ── Redis (OPTIONAL) ──────────────────────────────────────────────────────────
# Only needed if running Celery workers
REDIS_URL=redis://localhost:6379/0

# ── Free Tier Mode (IMPORTANT) ────────────────────────────────────────────────
# If TRUE:
# - No Redis needed
# - No Celery worker needed
# - Tasks run synchronously
FREE_TIER=True

# ── Channels (WebSockets) ─────────────────────────────────────────────────────
# If TRUE → no Redis needed for WebSockets
USE_IN_MEMORY_CHANNELS=True

# ── Cloudinary (REQUIRED for media uploads) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
DEFAULT_FROM_EMAIL=AI-MSHM <noreply@yourdomain.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://awhares.vercel.app

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173